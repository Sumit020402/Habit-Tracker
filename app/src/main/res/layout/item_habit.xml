<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Checkbox + Name + Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbComplete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#6200EE"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvHabitName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FF6D00"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Action buttons -->
            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#6200EE"/>

            <ImageButton
                android:id="@+id/btnProgress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#03DAC6"
                android:layout_marginStart="4dp"/>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#E53935"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Day Chips Row -->
        <LinearLayout
            android:id="@+id/dayChipsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tvDay1"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay2"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay3"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay4"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay5"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay6"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginEnd="4dp"
                android:background="@drawable/bg_day_chip_inactive"/>
            <TextView android:id="@+id/tvDay7"
                android:layout_width="34dp" android:layout_height="34dp"
                android:gravity="center" android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_day_chip_inactive"/>

        </LinearLayout>

        <!-- Goal Progress Row (only shown if habit has a goal) -->
        <LinearLayout
            android:id="@+id/goalRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/goalProgressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressTint="#6200EE"
                android:progressBackgroundTint="#E0E0E0"
                android:max="100"/>

            <!-- Progress text + increment button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvGoalProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#444444"/>

                <Button
                    android:id="@+id/btnIncrement"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="+1"
                    android:textSize="13sp"
                    android:paddingHorizontal="14dp"
                    android:backgroundTint="#6200EE"
                    android:textColor="#FFFFFF"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Reset"
                    android:textSize="12sp"
                    android:paddingHorizontal="10dp"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="#666666"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>